# =========================================================
# QLSV Frontend Environment
# Copy file nay thanh: frontend/.env
# Chi cac bien bat dau bang VITE_ moi duoc Vite dua vao frontend.
# Khong dat secret/API key rieng tu trong file frontend.
# =========================================================


# =========================================================
# 1) API BACKEND
# =========================================================

# Base URL frontend dung de goi backend.
# Local nen de /api de Vite proxy sang backend va giu cookie same-origin.
VITE_API_URL=/api

# Target backend local cho Vite dev proxy.
# Bien nay chi dung khi chay npm run dev.
VITE_API_TARGET=http://localhost:5000

# Production goi API truc tiep theo domain backend thi co the dat:
# VITE_API_URL=https://your-backend.example.com/api
# VITE_API_TARGET=


# =========================================================
# 2) VITE DEV SERVER
# =========================================================

# Cac host phu duoc phep truy cap Vite dev server, phan cach bang dau phay.
# Dung khi test qua LAN, tunnel, custom domain dev...
# Vi du:
# VITE_DEV_ALLOWED_HOSTS=192.168.1.10,my-dev-domain.local
VITE_DEV_ALLOWED_HOSTS=


# =========================================================
# 3) GIAO DIEN DANG NHAP - TUY CHON
# =========================================================

# Anh nen trang dang nhap mobile/portrait.
# Co the la URL public hoac duong dan trong public/, vi du: /login-bg.jpg
VITE_LOGIN_BACKGROUND_IMAGE_URL=

# Logo trang dang nhap mobile/portrait.
# Co the la URL public hoac duong dan trong public/, vi du: /logo-qlsv.png
VITE_LOGIN_LOGO_URL=/logo-qlsv.png


# =========================================================
# 4) GOOGLE MAPS - TUY CHON
# =========================================================

# Link base khi UI can mo Google Maps theo toa do/truy van.
# Giu mac dinh neu khong co yeu cau rieng.
VITE_MAPS_QUERY_URL=https://www.google.com/maps?q=
